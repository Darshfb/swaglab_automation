<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Saucedemo Test Suite" parallel="classes" thread-count="3">
    <listeners>
        <listener class-name="com.saucedemo.listeners.TestListener" />
        <listener class-name="com.saucedemo.listeners.AnnotationTransformer" />
    </listeners>
    <test name="E2E Tests">
        <packages>
            <package name="com.saucedemo.tests"/>
        </packages>
    </test>
</suite>
